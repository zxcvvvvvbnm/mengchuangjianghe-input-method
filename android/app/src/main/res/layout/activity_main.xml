<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <!-- 第一步：启用 + 切换 两个胶囊 -->
    <LinearLayout
        android:id="@+id/onboarding_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <Button
            android:id="@+id/btn_pill_enable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pill_enable_ime"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingVertical="14dp"
            android:background="@drawable/bg_capsule"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_pill_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pill_switch_ime"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingVertical="14dp"
            android:background="@drawable/bg_capsule"
            android:layout_marginBottom="12dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
    </LinearLayout>

    <!-- 第二步：选择键盘类型（9键/26键/手写/笔画）圆角长方卡 + 确定 -->
    <ScrollView
        android:id="@+id/keyboard_style_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <FrameLayout
                    android:id="@+id/card_9key"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/preview_9key"
                        android:contentDescription="@string/keyboard_style_9key" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:text="@string/keyboard_style_9key"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/card_26key"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/preview_26key"
                        android:contentDescription="@string/keyboard_style_26key" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:text="@string/keyboard_style_26key"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <FrameLayout
                    android:id="@+id/card_handwrite"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/preview_handwrite"
                        android:contentDescription="@string/keyboard_style_handwrite" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:text="@string/keyboard_style_handwrite"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/card_stroke"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">
                        <include
                            layout="@layout/keyboard_preview_stroke_keys"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="@string/keyboard_style_stroke"
                            android:textSize="14sp"
                            android:textColor="@color/black" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_keyboard_style_confirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/keyboard_style_confirm"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:paddingVertical="14dp"
                android:background="@drawable/bg_capsule"
                android:layout_marginTop="24dp" />
        </LinearLayout>
    </ScrollView>

    <!-- 首页：顶部搜索 + 两列皮肤列表 -->
    <FrameLayout
        android:id="@+id/home_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <include
            layout="@layout/home_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>
</FrameLayout>
