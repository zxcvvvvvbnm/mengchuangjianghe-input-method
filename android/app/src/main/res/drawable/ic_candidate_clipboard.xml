<?xml version="1.0" encoding="utf-8"?>
<!-- 剪刀图标：叉号 + 两条斜线顶端各一小半圆 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="20dp"
    android:height="20dp"
    android:viewportWidth="20"
    android:viewportHeight="20">
    <!-- 从左往右下的斜线 \ -->
    <path
        android:pathData="M4,16 L16,4"
        android:strokeWidth="1.8"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <!-- 从右往左下的斜线 / -->
    <path
        android:pathData="M16,16 L4,4"
        android:strokeWidth="1.8"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <!-- \ 线右上端小半圆 -->
    <path
        android:pathData="M15,5 m-1.2,0 a1.2,1.2 0,1 1,2.4 0 a1.2,1.2 0,1 1,-2.4 0"
        android:strokeWidth="1.2"
        android:strokeColor="#FFFFFF"
        android:fillColor="#00000000" />
    <!-- / 线左上端小半圆 -->
    <path
        android:pathData="M5,5 m-1.2,0 a1.2,1.2 0,1 1,2.4 0 a1.2,1.2 0,1 1,-2.4 0"
        android:strokeWidth="1.2"
        android:strokeColor="#FFFFFF"
        android:fillColor="#00000000" />
</vector>
